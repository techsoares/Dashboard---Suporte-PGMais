# Email do Jira (conta de serviço ou pessoal)
JIRA_EMAIL=seu.email@pgmais.com.br
# Token de API do Jira — gere em: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=your_jira_api_token_here
JIRA_BASE_URL=https://pgmais.atlassian.net/
JIRA_PROJECT=ON

# Segredo JWT — OBRIGATÓRIO, gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# Segredo para proteger o endpoint POST /api/refresh
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
REFRESH_SECRET=your_refresh_secret_here

# (Opcional) Email e hash bcrypt do admin
# Gere o hash com: python -c "import bcrypt; print(bcrypt.hashpw(b'sua_senha', bcrypt.gensalt()).decode())"
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Origens CORS permitidas (separadas por vírgula), além de localhost
# Exemplo: ALLOWED_ORIGINS=https://dashboard.pgmais.com.br
ALLOWED_ORIGINS=

# IA Insights — powered by OpenRouter (claude-sonnet-4.6)
# Obtenha sua chave em: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
