JIRA_EMAIL=seu-email@empresa.com.br
JIRA_TOKEN=seu-token-aqui
JIRA_BASE_URL=https://sua-empresa.atlassian.net
JIRA_PROJECT=XX

# Segredo para proteger o endpoint POST /api/refresh
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
REFRESH_SECRET=seu-segredo-aqui

# Origens CORS permitidas (separadas por vírgula), além de localhost
# Exemplo: ALLOWED_ORIGINS=https://dashboard.pgmais.com.br
ALLOWED_ORIGINS=

# IA Insights — powered by OpenRouter (claude-sonnet-4.6)
# Obtenha sua chave em: https://openrouter.ai/
OPENROUTER_API_KEY=sua-chave-aqui
